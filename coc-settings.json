{
    "languageserver": {
        "erlang": {
            "command": "erlang_ls",
            "filetypes": ["erlang"]
        },
        "haskell": {
            "command": "haskell-language-server-wrapper",
            "args": ["--lsp"],
            "rootPatterns": [
                "*.cabal",
                "stack.yaml",
                "cabal.project",
                "package.yaml"
            ],
            "filetypes": [
                "hs",
                "lhs",
                "haskell"
            ],
            "initializationOptions": {
                "haskell": {
                }
            }
        }
    },
    "diagnostic": {
        "level": "information"
    },
    "coc": {
        "preferences": {
            "jumpCommand": "tab drop"
        }
    }
}
